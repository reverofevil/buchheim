{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023"],
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node"],
        "allowImportingTsExtensions": true,
        "module": "ESNext",
        "moduleResolution": "Bundler"
    },
    "include": ["src/index.ts", "src/*.test.ts", "examples/*.ts"]
}
